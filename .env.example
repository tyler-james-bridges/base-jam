# Production: dedicated Base provider first, official rate-limited endpoint second.
BASE_RPC_HTTP_URLS=https://api.developer.coinbase.com/rpc/v1/base/YOUR_CDP_CLIENT_API_KEY,https://mainnet.base.org
# Backward-compatible single-endpoint option:
# BASE_RPC_HTTP_URL=https://mainnet.base.org

# At least 32 random bytes in production. Server-only.
RUN_TICKET_SECRET=replace-with-a-long-random-secret
SESSION_SECRET=replace-with-a-different-long-random-secret

# Set to the canonical production URL after deployment.
NEXT_PUBLIC_APP_URL=http://localhost:3000
